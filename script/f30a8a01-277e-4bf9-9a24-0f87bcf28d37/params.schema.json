{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/params.schema.json",
  "title": "Rendered Params Schema",
  "type": "object",
  "required": ["input_file", "plot_type"],
  "properties": {
    "group_field": { "type": "string" },
    "input_file": {
      "type": "object",
      "required": ["content", "sample", "x_var", "group1_vars", "group2_vars"],
      "properties": {
        "content": { "type": "string", "minLength": 1 },
        "sample": {},
        "x_var": {},
        "y_var": {},
        "panel_var": {},
        "group1_vars": {},
        "group2_vars": {}
      },
      "additionalProperties": true
    },
    "plot_type": {
      "type": "string",
      "enum": ["violin", "scatter", "boxplot"]
    },
    "show_stats": { "type": "boolean" },
    "stat_label": {
      "type": "string",
      "enum": ["p", "q", "both"]
    },
    "point_size": { "type": "number", "minimum": 0 },
    "point_alpha": { "type": "number", "minimum": 0, "maximum": 1 },
    "output_name": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
